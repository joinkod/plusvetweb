{
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/admin/config.yml",
      "dest": "/admin/config.yml"
    },
    {
      "src": "/admin/decap-cms.js",
      "dest": "/admin/decap-cms.js"
    },
    {
      "src": "/admin(/)?",
      "dest": "/admin/index.html"
    },
    {
      "src": "/post\\.html",
      "dest": "/post.html"
    },
    {
      "src": "/posts/(.*)",
      "dest": "/posts/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)\\.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "image/svg+xml" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
